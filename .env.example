# Get a token: https://discord.com/developers/applications → Bot
DISCORD_TOKEN=

# Discord upload cap for your server (25 free, higher with boosts)
MAX_FILE_SIZE_MB=25

# Rolling per-user limit (failed downloads don't count)
MAX_DOWNLOADS_PER_USER_PER_HOUR=10

DOWNLOAD_TIMEOUT_SECONDS=180
COMPRESS_VIDEOS=true

# Leave empty to watch every channel. Comma-separated snowflakes otherwise.
ALLOWED_CHANNEL_IDS=
IGNORED_CHANNEL_IDS=

TEMP_DIR=/tmp/discord-video-bot
LOG_FILE=logs/bot.log
LOG_LEVEL=INFO

# Server channels only — Discord won't let bots delete user DMs reliably
DELETE_ORIGINAL_MESSAGE=true

# What shows above the uploaded file
INCLUDE_AUTHOR=true
INCLUDE_TITLE=true
INCLUDE_SOURCE_URL=false

# true = try random links with yt-dlp; false = only known social hosts
ALLOW_GENERIC_URLS=true
EXTRA_DENY_HOSTS=

CONCURRENT_DOWNLOAD_LIMIT=3
