# Required: Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Maximum upload size in MB (Discord free/boost tiers: 25 / 50 / 100)
MAX_FILE_SIZE_MB=25

# Max downloads per user per rolling hour (failed jobs are refunded)
MAX_DOWNLOADS_PER_USER_PER_HOUR=10

# yt-dlp download timeout in seconds
DOWNLOAD_TIMEOUT_SECONDS=180

# Re-encode with ffmpeg when over the safe upload budget
COMPRESS_VIDEOS=true

# Comma-separated channel IDs. Empty = all channels (except ignored)
ALLOWED_CHANNEL_IDS=
IGNORED_CHANNEL_IDS=

TEMP_DIR=/tmp/discord-video-bot
LOG_FILE=logs/bot.log
LOG_LEVEL=INFO

# Delete the original link message in servers (after success for generic URLs)
DELETE_ORIGINAL_MESSAGE=true

# Caption on the re-uploaded video
INCLUDE_AUTHOR=true
INCLUDE_TITLE=true
INCLUDE_SOURCE_URL=false

# Try any non-blocked URL with yt-dlp (1000+ sites). Known social hosts always tried.
ALLOW_GENERIC_URLS=true
# Extra hosts to never try (comma-separated), e.g. example.com,cdn.mysite.com
EXTRA_DENY_HOSTS=

CONCURRENT_DOWNLOAD_LIMIT=3
