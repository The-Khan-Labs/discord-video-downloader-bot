# Required — paste the bot token from Discord Developer Portal → Bot
DISCORD_TOKEN=

# Max upload size in MB (25 on normal servers; higher if the server is boosted)
MAX_FILE_SIZE_MB=25

# How many downloads each user can start per hour
MAX_DOWNLOADS_PER_USER_PER_HOUR=10

# Give up if a download takes longer than this (seconds)
DOWNLOAD_TIMEOUT_SECONDS=180

# Shrink videos that are too big for Discord (needs ffmpeg)
COMPRESS_VIDEOS=true

# Only these channels (leave empty = all channels). Comma-separated IDs.
ALLOWED_CHANNEL_IDS=

# Never use the bot in these channels
IGNORED_CHANNEL_IDS=

# Where temp downloads go (deleted after each video)
TEMP_DIR=/tmp/discord-video-bot

# Log file
LOG_FILE=logs/bot.log
LOG_LEVEL=INFO

# Remove the original message that only had the link
DELETE_ORIGINAL_MESSAGE=true

# Text above the uploaded video
INCLUDE_AUTHOR=true
INCLUDE_TITLE=true
INCLUDE_SOURCE_URL=false

# Also try non-social links with yt-dlp
ALLOW_GENERIC_URLS=true

# Never try these websites (comma-separated), e.g. example.com
EXTRA_DENY_HOSTS=

# How many videos can download at the same time
CONCURRENT_DOWNLOAD_LIMIT=3
