# Required: Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Maximum upload size in MB (Discord free/boost tiers vary: 25 / 50 / 100)
MAX_FILE_SIZE_MB=25

# Abuse protection: max successful-attempt downloads per user per rolling hour
MAX_DOWNLOADS_PER_USER_PER_HOUR=10

# yt-dlp download timeout in seconds (compression of big files may take longer)
DOWNLOAD_TIMEOUT_SECONDS=180

# When a download is over MAX_FILE_SIZE_MB, re-encode with ffmpeg until it fits
# (or give up after progressive quality steps). Requires ffmpeg + ffprobe.
COMPRESS_VIDEOS=true

# Comma-separated channel IDs. Empty = all channels (except ignored)
ALLOWED_CHANNEL_IDS=

# Comma-separated channel IDs to never process
IGNORED_CHANNEL_IDS=

# Temporary download directory
TEMP_DIR=/tmp/discord-video-bot

# Log file path (directory is created automatically)
LOG_FILE=logs/bot.log

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Delete the original user message after a successful re-upload
DELETE_ORIGINAL_MESSAGE=true

# Include the source URL in the re-upload caption
INCLUDE_SOURCE_URL=false

# Max simultaneous downloads across the whole bot
CONCURRENT_DOWNLOAD_LIMIT=3
